{
    "version": 2,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": ["src/**", "logos/**"]
            }
        }
    ],
    "routes": [
        { "src": "/(.*)", "dest": "api/index.js" }
    ]
}
