{
  "name": "stremio-custom-row-factory",
  "version": "1.0.0",
  "description": "A Stremio addon that creates N custom home-screen rows from a JSON config.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "lint:js": "eslint \"src/**/*.js\" \"api/**/*.js\" \"index.js\"",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "lint:html": "htmlhint \"src/**/*.html\"",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "format": "prettier --write \"src/**/*.{js,css,html}\" \"api/**/*.js\" \"index.js\"",
    "clean-gist": "node scripts/clean-gist.js"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jimp": "^1.6.0",
    "stremio-addon-sdk": "^1.6.10"
  },
  "engines": {
    "node": ">=14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "htmlhint": "^1.9.2",
    "prettier": "^3.8.1",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-prettier": "^5.0.3"
  }
}
